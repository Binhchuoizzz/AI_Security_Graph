// SENTINEL - so do luong chay (nguon cho Figure: sentinel_flow.png, ban tieng Viet)
// Render: dot -Tpng -Gdpi=200 sentinel_flow.dot -o sentinel_flow.png
digraph sentinel_flow {
    rankdir=TB;
    bgcolor="white";
    node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=12, margin="0.18,0.10"];
    edge [fontname="Helvetica", fontsize=10, color="#444444"];

    start    [label="Nhật ký luồng mạng đầu vào", shape=oval, fillcolor="#cfe8ff"];
    rule     [label="TẦNG 1 - Rule Engine\n(Whitelist | chữ ký WAF & chèn mã\n| Welford Z-Score, warmup 100)", fillcolor="#e8f5e9"];
    sig      [label="Khớp chữ ký /\nWhitelist?", shape=diamond, fillcolor="#fff3cd"];
    fast     [label="Whitelist -> DROP\nWAF/SQLi/XSS -> BLOCK_IP", fillcolor="#f8d7da"];
    score    [label="Điểm rủi ro >= ngưỡng?\n(luật tĩnh + Welford Z > 3.5 sigma)", shape=diamond, fillcolor="#fff3cd"];
    benign   [label="DROP / LOG\n(ghi vào nhật ký quyết định)", fillcolor="#e2e3e5"];
    escalate [label="ESCALATE -> TẦNG 2", fillcolor="#cfe8ff"];

    guard    [label="Guardrails\n(khai thác khuôn mẫu Drain +\nđóng gói phân tách nonce)", fillcolor="#e8f5e9"];
    rag      [label="Truy xuất Dual-RAG (FAISS + BM25, RRF k=60)\nBộ đệm Ngữ nghĩa + Bộ nhớ Đe dọa (chuỗi APT)", fillcolor="#e8f5e9"];
    triage   [label="Phân loại LLM\n(Gemma-2-9B-IT Q6_K, temp 0.1)\n-> một phán quyết JSON", fillcolor="#e8f5e9"];
    valid    [label="DecisionValidator\n(BLOCK_IP cần độ tin cậy >= 0.5;\nlá chắn đồng thuận Tầng 1/Tầng 2)", shape=diamond, fillcolor="#fff3cd"];
    route    [label="Định tuyến theo hành động", shape=diamond, fillcolor="#fff3cd"];

    block    [label="BLOCK_IP / ALERT\n-> Bộ thực thi (Firewall MOCK)\n+ luật PENDING chờ HITL", fillcolor="#f8d7da"];
    hitl     [label="AWAIT_HITL\n-> hàng đợi HITL Streamlit", fillcolor="#ffe0b2"];
    endlog   [label="LOG / DROP -> kết thúc chu kỳ", fillcolor="#e2e3e5"];

    audit    [label="Ghi bản ghi kiểm toán chuỗi HMAC", fillcolor="#d1c4e9"];
    done     [label="Kết thúc xử lý", shape=oval, fillcolor="#e2e3e5"];

    start -> rule -> sig;
    sig -> fast      [label="có"];
    sig -> score     [label="không"];
    score -> benign  [label="không"];
    score -> escalate[label="có"];

    escalate -> guard -> rag -> triage -> valid -> route;
    route -> block   [label="BLOCK_IP / ALERT"];
    route -> hitl    [label="AWAIT_HITL"];
    route -> endlog  [label="LOG / DROP"];

    fast   -> audit;
    block  -> audit;
    hitl   -> audit;
    benign -> done;
    endlog -> done;
    audit  -> done;
}
