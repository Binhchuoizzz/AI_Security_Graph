// SENTINEL runtime execution flow (source of truth for Figure: sentinel_flow.png)
// Render: dot -Tpng -Gdpi=200 sentinel_flow.dot -o sentinel_flow.png
digraph sentinel_flow {
    rankdir=TB;
    bgcolor="white";
    node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=12, margin="0.18,0.10"];
    edge [fontname="Helvetica", fontsize=10, color="#444444"];

    start    [label="Network Flow Ingested", shape=oval, fillcolor="#cfe8ff"];
    rule     [label="TIER-1 Rule Engine\n(Whitelist | WAF & Injection signatures\n| Welford Z-Score, warmup 100)", fillcolor="#e8f5e9"];
    sig      [label="Signature / Whitelist\nmatch?", shape=diamond, fillcolor="#fff3cd"];
    fast     [label="Whitelist -> DROP\nWAF/SQLi/XSS -> BLOCK_IP", fillcolor="#f8d7da"];
    score    [label="Risk score >= threshold?\n(static rules + Welford Z > 3.5 sigma)", shape=diamond, fillcolor="#fff3cd"];
    benign   [label="DROP / LOG\n(write to decision log)", fillcolor="#e2e3e5"];
    escalate [label="ESCALATE -> TIER-2", fillcolor="#cfe8ff"];

    guard    [label="Guardrails\n(Drain template mining +\nnonce Delimited Encapsulation)", fillcolor="#e8f5e9"];
    rag      [label="Dual-RAG retrieval (FAISS + BM25, RRF k=60)\nSemantic Cache + Threat Memory (APT chain)", fillcolor="#e8f5e9"];
    triage   [label="LLM Triage\n(Gemma-2-9B-IT Q6_K, temp 0.1)\n-> single JSON verdict", fillcolor="#e8f5e9"];
    valid    [label="DecisionValidator\n(BLOCK_IP needs conf >= 0.5;\nTier-1/Tier-2 consensus guard)", shape=diamond, fillcolor="#fff3cd"];
    route    [label="Route by action", shape=diamond, fillcolor="#fff3cd"];

    block    [label="BLOCK_IP / ALERT\n-> Action Executor (Firewall MOCK)\n+ PENDING rule for HITL", fillcolor="#f8d7da"];
    hitl     [label="AWAIT_HITL\n-> Streamlit HITL queue", fillcolor="#ffe0b2"];
    endlog   [label="LOG / DROP -> end cycle", fillcolor="#e2e3e5"];

    audit    [label="Write HMAC-chained audit record", fillcolor="#d1c4e9"];
    done     [label="End Processing", shape=oval, fillcolor="#e2e3e5"];

    start -> rule -> sig;
    sig -> fast      [label="yes"];
    sig -> score     [label="no"];
    score -> benign  [label="no"];
    score -> escalate[label="yes"];

    escalate -> guard -> rag -> triage -> valid -> route;
    route -> block   [label="BLOCK_IP / ALERT"];
    route -> hitl    [label="AWAIT_HITL"];
    route -> endlog  [label="LOG / DROP"];

    fast   -> audit;
    block  -> audit;
    hitl   -> audit;
    benign -> done;
    endlog -> done;
    audit  -> done;
}
