// SENTINEL holistic architecture block diagram (source of truth for soc_ai_concept.png)
// Render: dot -Tpng -Gdpi=200 soc_ai_concept.dot -o soc_ai_concept.png
digraph sentinel_arch {
    rankdir=TB;
    bgcolor="white";
    compound=true;
    node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=12, margin="0.16,0.09", color="#37474f"];
    edge [fontname="Helvetica", fontsize=10, color="#455a64"];

    // ---------- Data Ingestion ----------
    subgraph cluster_ingest {
        label="Data Ingestion";
        labeljust="l";
        style="dashed,rounded";
        color="#90a4ae";
        fontname="Helvetica-Bold";
        pcap [label="Raw Packet Capture\n(PCAP)", fillcolor="#e3f2fd"];
        flow [label="Network Flow Logs\n(NetFlow / Sysmon)", fillcolor="#e3f2fd"];
    }

    // ---------- Tier-1 ----------
    subgraph cluster_tier1 {
        label="TIER-1: STATELESS WIRE-SPEED FILTER";
        labeljust="l";
        style="rounded,filled";
        color="#a5d6a7";
        fillcolor="#e8f5e9";
        fontname="Helvetica-Bold";
        rule  [label="Rule Engine\n(Regex Signatures)", fillcolor="#ffffff"];
        welf  [label="Welford Engine\n(Online Statistics)", fillcolor="#ffffff"];
        sess  [label="Session Baseline\n(Per-IP Baseline)", fillcolor="#ffffff"];
        guard1 [label="Z-Score / Static Guard\n(Decision Point)", shape=diamond, fillcolor="#fff3cd"];
    }

    // ---------- Tier-2 ----------
    subgraph cluster_tier2 {
        label="TIER-2: STATEFUL COGNITIVE REASONING LAYER";
        labeljust="l";
        style="rounded,filled";
        color="#90caf9";
        fillcolor="#e3f2fd";
        fontname="Helvetica-Bold";
        grd   [label="AI Security Guardrails\n(Delimited Encapsulation)", fillcolor="#ffffff"];
        miner [label="Log Template Miner\n(Drain + Token Budget)", fillcolor="#ffffff"];
        cache [label="Semantic Cache\n(In-Memory LRU, SHA-256 keys)", fillcolor="#ffffff"];
        fsm   [label="LangGraph FSM\n(Orchestration Engine)", fillcolor="#ffffff"];
        tmem  [label="Threat Memory\n(SQLite DB)", fillcolor="#ffffff"];
        hmac  [label="HMAC Protection\n(Audit Logs)", fillcolor="#ffffff"];
        llm   [label="Quantized LLM\n(Gemma-2-9B-IT Q6_K)", fillcolor="#ffe0b2"];
        drag  [label="Dual-RAG Hybrid Search\n(MITRE ATT&CK + NIST SP 800-61r2)", fillcolor="#ffffff"];
    }

    // ---------- Response ----------
    subgraph cluster_resp {
        label="RESPONSE & VISUALIZATION";
        labeljust="l";
        style="rounded,filled";
        color="#ffcc80";
        fillcolor="#fff3e0";
        fontname="Helvetica-Bold";
        ui   [label="Streamlit UI\n(SOC Dashboard & HITL Queue)", fillcolor="#ffffff"];
        fw   [label="Firewall Orchestration\n(Block action)", fillcolor="#ffffff"];
    }

    // ---------- Edges ----------
    pcap -> guard1 [lhead=cluster_tier1, style=invis];
    flow -> rule   [lhead=cluster_tier1];
    pcap -> rule;

    rule -> guard1;
    welf -> guard1;
    welf -> sess [style=dotted, label="update"];
    guard1 -> sess [style=dotted];

    guard1 -> grd  [color="#c62828", fontcolor="#c62828", label="Escalate\n(Z > threshold)", lhead=cluster_tier2];
    guard1 -> tmem [style=dashed, label="Log directly\n(Benign)"];

    grd -> miner -> cache -> fsm;
    fsm -> tmem [style=dotted];
    fsm -> hmac [style=dotted];
    fsm -> llm  [style=dotted];
    fsm -> drag [style=dotted];

    fsm -> ui   [lhead=cluster_resp, label="verdict"];
    ui  -> fw   [color="#e65100", fontcolor="#e65100", label="HITL Approval"];
}
