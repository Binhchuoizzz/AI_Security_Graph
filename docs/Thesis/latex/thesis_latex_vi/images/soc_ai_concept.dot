// SENTINEL - So do khoi kien truc tong the (nguon cua soc_ai_concept.png)
// Render: dot -Tpng -Gdpi=200 soc_ai_concept.dot -o soc_ai_concept.png
digraph sentinel_arch {
    rankdir=TB;
    bgcolor="white";
    compound=true;
    node [shape=box, style="rounded,filled", fontname="DejaVu Sans", fontsize=12, margin="0.16,0.09", color="#37474f"];
    edge [fontname="DejaVu Sans", fontsize=10, color="#455a64"];

    subgraph cluster_ingest {
        label="Thu nạp Dữ liệu";
        labeljust="l";
        style="dashed,rounded";
        color="#90a4ae";
        fontname="DejaVu Sans Bold";
        pcap [label="Bắt gói tin thô\n(PCAP)", fillcolor="#e3f2fd"];
        flow [label="Nhật ký luồng mạng\n(NetFlow / Sysmon)", fillcolor="#e3f2fd"];
    }

    subgraph cluster_tier1 {
        label="TẦNG 1: BỘ LỌC PHI TRẠNG THÁI TỐC ĐỘ ĐƯỜNG TRUYỀN";
        labeljust="l";
        style="rounded,filled";
        color="#a5d6a7";
        fillcolor="#e8f5e9";
        fontname="DejaVu Sans Bold";
        rule  [label="Bộ máy Luật\n(Chữ ký Regex)", fillcolor="#ffffff"];
        welf  [label="Bộ máy Welford\n(Thống kê trực tuyến)", fillcolor="#ffffff"];
        sess  [label="Đường cơ sở Phiên\n(Theo từng IP)", fillcolor="#ffffff"];
        guard1 [label="Z-Score / Lá chắn tĩnh\n(Điểm quyết định)", shape=diamond, fillcolor="#fff3cd"];
    }

    subgraph cluster_tier2 {
        label="TẦNG 2: TẦNG SUY LUẬN NHẬN THỨC CÓ TRẠNG THÁI";
        labeljust="l";
        style="rounded,filled";
        color="#90caf9";
        fillcolor="#e3f2fd";
        fontname="DejaVu Sans Bold";
        grd   [label="Rào chắn Bảo mật AI\n(Đóng gói phân tách)", fillcolor="#ffffff"];
        miner [label="Khai phá Khuôn mẫu Log\n(Drain + Ngân sách Token)", fillcolor="#ffffff"];
        cache [label="Bộ đệm Ngữ nghĩa\n(LRU trong bộ nhớ, khóa SHA-256)", fillcolor="#ffffff"];
        fsm   [label="LangGraph FSM\n(Bộ điều phối)", fillcolor="#ffffff"];
        tmem  [label="Bộ nhớ Đe dọa\n(CSDL SQLite)", fillcolor="#ffffff"];
        hmac  [label="Bảo vệ HMAC\n(Nhật ký kiểm toán)", fillcolor="#ffffff"];
        llm   [label="LLM lượng tử hóa\n(Gemma-2-9B-IT Q6_K)", fillcolor="#ffe0b2"];
        drag  [label="Tìm kiếm lai Dual-RAG\n(MITRE ATT&CK + NIST SP 800-61r2)", fillcolor="#ffffff"];
    }

    subgraph cluster_resp {
        label="PHẢN HỒI & TRỰC QUAN HÓA";
        labeljust="l";
        style="rounded,filled";
        color="#ffcc80";
        fillcolor="#fff3e0";
        fontname="DejaVu Sans Bold";
        ui   [label="Giao diện Streamlit\n(Bảng điều khiển SOC & Hàng đợi HITL)", fillcolor="#ffffff"];
        fw   [label="Điều phối Tường lửa\n(Hành động chặn)", fillcolor="#ffffff"];
    }

    pcap -> rule;
    flow -> rule   [lhead=cluster_tier1];

    rule -> guard1;
    welf -> guard1;
    welf -> sess [style=dotted, label="cập nhật"];
    guard1 -> sess [style=dotted];

    guard1 -> grd  [color="#c62828", fontcolor="#c62828", label="Leo thang\n(Z > ngưỡng)", lhead=cluster_tier2];
    guard1 -> tmem [style=dashed, label="Ghi log trực tiếp\n(Lành tính)"];

    grd -> miner -> cache -> fsm;
    fsm -> tmem [style=dotted];
    fsm -> hmac [style=dotted];
    fsm -> llm  [style=dotted];
    fsm -> drag [style=dotted];

    fsm -> ui   [lhead=cluster_resp, label="phán quyết"];
    ui  -> fw   [color="#e65100", fontcolor="#e65100", label="Duyệt HITL"];
}
