# ================================================================
# SENTINEL — Environment Configuration
# ================================================================

# REDIS CONFIGURATION
REDIS_URL=redis://:SentinelSecurePass2026!@localhost:6379/0
REDIS_PASSWORD=SentinelSecurePass2026!

# MLFLOW TRACKING URL
MLFLOW_TRACKING_URI=http://localhost:5001

# LLM CONFIGURATION (llama.cpp server — auto-started by docker-compose)
# Khi chạy trong Docker: http://llm:8080/v1 (auto-set bởi docker-compose)
# Khi chạy ngoài Docker (venv): http://127.0.0.1:5000/v1
LLM_API_BASE=http://127.0.0.1:5000/v1
LLM_API_KEY=sk-placeholder-local-only
MOCK_LLM=0  # Set to 1 to mock LLM responses when server is down

# LLM MODEL PATH (for docker-compose volume mount)
# Đường dẫn tuyệt đối tới thư mục chứa file .gguf trên máy Host
LLM_MODEL_DIR=/home/binhchuoiz/text-generation-webui/user_data/models
LLM_MODEL_FILE=gemma-2-9b-it-Q6_K.gguf

# NEO4J CONFIGURATION (Optional — V2 Architecture)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=SentinelGraphPass2026!

# UI AUTHENTICATION HASHES (Streamlit bcrypt hashes)
SENTINEL_ANALYST_HASH='$2b$12$somehash'
SENTINEL_MANAGER_HASH='$2b$12$otherhash'
