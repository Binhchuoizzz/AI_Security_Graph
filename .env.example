# ================================================================
# SENTINEL — Environment Configuration
# ================================================================

# REDIS CONFIGURATION
# Secret CHỈ sống trong .env (gitignored) — file example này chỉ giữ placeholder.
# Đặt mật khẩu mạnh của bạn rồi giữ 2 biến nhất quán với nhau.
REDIS_PASSWORD=change-me-strong-password
REDIS_URL=redis://:change-me-strong-password@localhost:6379/0

# MLFLOW TRACKING URL
MLFLOW_TRACKING_URI=http://localhost:5001

# LLM CONFIGURATION (llama.cpp server — auto-started by docker-compose)
# Khi chạy trong Docker: http://llm:8080/v1 (auto-set bởi docker-compose)
# Khi chạy ngoài Docker (venv): http://127.0.0.1:5000/v1
LLM_API_BASE=http://127.0.0.1:5000/v1
LLM_API_KEY=sk-placeholder-local-only
MOCK_LLM=0  # Set to 1 to mock LLM responses when server is down

# LLM MODEL PATH (for docker-compose volume mount)
# Đường dẫn tuyệt đối tới thư mục chứa file .gguf trên máy Host
LLM_MODEL_DIR=/home/binhchuoiz/text-generation-webui/user_data/models
LLM_MODEL_FILE=gemma-2-9b-it-Q6_K.gguf

# NEO4J CONFIGURATION (Optional — V2 Architecture)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-neo4j-password

# UI AUTHENTICATION (PBKDF2-HMAC-SHA256, 100k vòng — KHÔNG phải bcrypt)
# Production BẮT BUỘC đặt cả 3 biến dưới (nếu trống -> rơi về HASH/SALT demo + cảnh báo).
# Sinh hash:  python -c "import hashlib,os; print(hashlib.pbkdf2_hmac('sha256', b'<mật_khẩu>', os.environ['SENTINEL_AUTH_SALT'].encode(), 100000).hex())"
SENTINEL_AUTH_SALT=please_change_this_to_a_unique_random_salt
SENTINEL_ANALYST_HASH=  # 64 ký tự hex PBKDF2 cho tài khoản analyst
SENTINEL_MANAGER_HASH=  # 64 ký tự hex PBKDF2 cho tài khoản manager

# STREAMING PUBLISHERS (tùy chọn — đã có default hợp lý)
# simulate_traffic.py (replay ground_truth):
SIMULATE_BATCH_SIZE=50
SIMULATE_DELAY=0.5
# stream_unified_online.py (luồng gộp CICIDS+DAPT+zero-day qua full pipeline):
UNIFIED_STREAM_BATCH=50
UNIFIED_STREAM_DELAY=0.3
